# AEGIS Server Environment Configuration
# Copy this file to .env and fill in your values
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# PostgreSQL connection (install PostgreSQL + PostGIS locally)
DATABASE_URL=postgresql://postgres:password@localhost:5432/aegis

# JWT secret for authentication tokens (change this to a random string)
JWT_SECRET=aegis-change-this-to-a-random-secret-string-2026

# Server port
PORT=3001

# OpenWeatherMap API key (free at https://openweathermap.org/api)
WEATHER_API_KEY=

# File upload directory
UPLOAD_DIR=./uploads

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Internal AI engine URL
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT=30000

# Dynamic content translation providers (server-side only)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/

DEEPL_API_KEY=
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate

# Optional comma-separated override list for LibreTranslate public/self-hosted endpoints
LIBRE_TRANSLATE_ENDPOINT=

# n8n workflow automation
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=add_n8n_api_key_here
# NASA FIRMS wildfire satellite data (free key from https://firms.modaps.eosdis.nasa.gov/api/area/)
NASA_FIRMS_API_KEY= add api key here
# Password reset URL base (token is appended as query string)
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# Alert Provider Configuration (Production)
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# SMTP Email Configuration (use Gmail, SendGrid, AWS SES, or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=alerts@aegis.gov.uk
SMTP_FROM_NAME=AEGIS Alert System

# Twilio SMS Configuration (sign up at https://www.twilio.com)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+447123456789

# Telegram Bot Configuration (create bot via @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp via Twilio (requires approved Twilio WhatsApp sender)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Web Push Notifications (VAPID keys - generate with: npx tsx src/utils/generateVapidKeys.ts)
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@aegis.gov.uk

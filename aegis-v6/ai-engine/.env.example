# ─── Service ──────────────────────────────────────────────────────────────
AI_ENGINE_PORT=8000
MODEL_REGISTRY_PATH=registry/model_versions
INTERNAL_API_KEY=aegis-internal-key-CHANGE-IN-PRODUCTION-MINIMUM-32-CHARS
DRIFT_THRESHOLD=0.15
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Data credentials (all optional — synthetic fallback if missing) ───────
# Copernicus CDS (ERA5, CHESS-SCAPE) — free at https://cds.climate.copernicus.eu
CDS_API_KEY=your-cds-api-key
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2

# NASA Earthdata (GPM, MODIS) — free at https://urs.earthdata.nasa.gov
NASA_EARTHDATA_USER=your-earthdata-username
NASA_EARTHDATA_PASS=your-earthdata-password

# CEDA Archive (HadUK, CHESS) — free at https://services.ceda.ac.uk
CEDA_USERNAME=your-ceda-username
CEDA_PASSWORD=your-ceda-password

# ─── Training ─────────────────────────────────────────────────────────────
SYNTHETIC_FALLBACK=true
AUTO_TRAIN_ON_STARTUP=false
TRAINING_DATA_PATH=data/processed
ACTIVE_REGION=scotland

# ─── UK Expansion (flip to true when ready to activate) ───────────────────
ENABLE_ENGLAND=false
ENABLE_WALES=false
ENABLE_NORTHERN_IRELAND=false

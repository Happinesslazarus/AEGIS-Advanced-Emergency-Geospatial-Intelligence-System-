{
  "name": "AEGIS - Emergency Response System",
  "short_name": "AEGIS",
  "description": "Advanced Emergency Geospatial Intelligence System — real-time disaster monitoring, alerts, and community safety tools",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0f172a",
  "theme_color": "#2563eb",
  "lang": "en",
  "dir": "auto",
  "categories": ["emergency", "safety", "weather", "government"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Report Emergency",
      "short_name": "SOS",
      "url": "/citizen?action=sos",
      "description": "Activate emergency SOS beacon",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Live Map",
      "short_name": "Map",
      "url": "/citizen?tab=map",
      "description": "View live disaster map"
    }
  ],
  "share_target": {
    "action": "/citizen?action=report",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "description",
      "files": [{ "name": "media", "accept": ["image/*", "video/*"] }]
    }
  }
}

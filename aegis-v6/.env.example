# AEGIS v6.9 — Environment Variables Template
# Copy to .env and fill in real values before deploying.

# ── Database ────────────────────────────────────────────────
DB_PASSWORD=aegis_secure_2026
DATABASE_URL=postgresql://postgres:aegis_secure_2026@localhost:5432/aegis

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string

# ── Region ──────────────────────────────────────────────────
AEGIS_REGION=scotland

# ── AI / LLM API Keys (free tiers) ─────────────────────────
# At least one LLM key is needed for chat to work.
# The system rotates between available providers automatically.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=

# ── Weather ─────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS (Twilio) ───────────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH=
TWILIO_FROM=

# ── Telegram Bot ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Web Push (VAPID) ──────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@aegis.gov.uk
